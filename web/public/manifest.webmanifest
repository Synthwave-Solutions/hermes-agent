{
  "name": "SynthPulse",
  "short_name": "SynthPulse",
  "description": "Premium Synthwave Solutions control dashboard for agent, gateway, and operations telemetry.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "browser"
  ],
  "background_color": "#0f172a",
  "theme_color": "#009dff",
  "orientation": "any",
  "categories": [
    "productivity",
    "business",
    "developer"
  ],
  "icons": [
    {
      "src": "/synthwave-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/synthwave-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}